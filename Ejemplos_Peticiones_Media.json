  "ejemplos_curl": {
    "get_todas_medias": "curl -X GET http://localhost:4000/api/media -H \"Content-Type: application/json\"",
    "post_crear_media": "curl -X POST http://localhost:4000/api/media -H \"Content-Type: application/json\" -d '{\"serial\": \"UNIVERS-002\", \"titulo\": \"E.T.\", \"urlPelicula\": \"https://www.peliculas.com/et\", \"anioEstreno\": 1982, \"genero\": \"GENERO_ID\", \"director\": \"DIRECTOR_ID\", \"productora\": \"PRODUCTORA_ID\", \"tipo\": \"TIPO_ID\"}'",
    "get_media_por_id": "curl -X GET http://localhost:4000/api/media/507f1f77bcf86cd799439019 -H \"Content-Type: application/json\"",
    "put_actualizar_media": "curl -X PUT http://localhost:4000/api/media/507f1f77bcf86cd799439019 -H \"Content-Type: application/json\" -d '{\"titulo\": \"Jaws: The Revenge\", \"anioEstreno\": 1987}'",
    "delete_media": "curl -X DELETE http://localhost:4000/api/media/507f1f77bcf86cd799439019 -H \"Content-Type: application/json\""
  },
  "ejemplos_javascript": {
    "get_todas_medias": {
      "codigo": "fetch('http://localhost:4000/api/media')\n  .then(response => response.json())\n  .then(data => console.log(data))\n  .catch(error => console.error('Error:', error));"
    },
    "post_crear_media": {
      "codigo": "fetch('http://localhost:4000/api/media', {\n  method: 'POST',\n  headers: {\n    'Content-Type': 'application/json'\n  },\n  body: JSON.stringify({\n    serial: 'UNIVERS-002',\n    titulo: 'E.T. the Extra-Terrestrial',\n    sinopsis: 'Un niño se hace amigo de un extraterrestre abandonado',\n    urlPelicula: 'https://www.peliculas.com/et',\n    imagen: 'https://www.imagenes.com/et.jpg',\n    anioEstreno: 1982,\n    genero: 'GENERO_ID',\n    director: 'DIRECTOR_ID',\n    productora: 'PRODUCTORA_ID',\n    tipo: 'TIPO_ID'\n  })\n})\n  .then(response => response.json())\n  .then(data => console.log(data))\n  .catch(error => console.error('Error:', error));"
    },
    "get_media_por_id": {
      "codigo": "fetch('http://localhost:4000/api/media/507f1f77bcf86cd799439019')\n  .then(response => response.json())\n  .then(data => console.log(data))\n  .catch(error => console.error('Error:', error));"
    },
    "put_actualizar_media": {
      "codigo": "fetch('http://localhost:4000/api/media/507f1f77bcf86cd799439019', {\n  method: 'PUT',\n  headers: {\n    'Content-Type': 'application/json'\n  },\n  body: JSON.stringify({\n    titulo: 'Jaws: The Revenge',\n    sinopsis: 'Los secretos de una playa de verano son revelados',\n    anioEstreno: 1987\n  })\n})\n  .then(response => response.json())\n  .then(data => console.log(data))\n  .catch(error => console.error('Error:', error));"
    },
    "delete_media": {
      "codigo": "fetch('http://localhost:4000/api/media/507f1f77bcf86cd799439019', {\n  method: 'DELETE',\n  headers: {\n    'Content-Type': 'application/json'\n  }\n})\n  .then(response => response.json())\n  .then(data => console.log(data))\n  .catch(error => console.error('Error:', error));"
    }
