      ],
      "respuesta_esperada": {
        "status": 201,
        "body": {
          "_id": "507f1f77bcf86cd799439015",
          "nombre": "Steven Spielberg",
          "estado": "Activo",
          "fechaCreacion": "2024-01-15T10:30:00.000Z",
          "fechaActualizacion": "2024-01-15T10:30:00.000Z"
        }
      }
    },
    "get_director_por_id": {
      "metodo": "GET",
      "url": "http://localhost:4000/api/director/507f1f77bcf86cd799439015",
      "headers": {
        "Content-Type": "application/json"
      },
      "descripcion": "Obtiene un director por su ID"
    },
    "put_actualizar_director": {
      "metodo": "PUT",
      "url": "http://localhost:4000/api/director/507f1f77bcf86cd799439015",
      "headers": {
        "Content-Type": "application/json"
      },
      "descripcion": "Actualiza un director",
      "body": {
        "nombre": "Steven Spielberg",
        "estado": "Inactivo"
