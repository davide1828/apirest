  "ejemplos_curl": {
    "director": {
      "crear": "curl -X POST http://localhost:4000/api/director -H \"Content-Type: application/json\" -d '{\"nombre\": \"Steven Spielberg\"}'",
      "obtener_todos": "curl -X GET http://localhost:4000/api/director -H \"Content-Type: application/json\"",
      "actualizar": "curl -X PUT http://localhost:4000/api/director/ID -H \"Content-Type: application/json\" -d '{\"nombre\": \"Steven Spielberg\", \"estado\": \"Inactivo\"}'",
      "eliminar": "curl -X DELETE http://localhost:4000/api/director/ID -H \"Content-Type: application/json\""
    },
    "productora": {
      "crear": "curl -X POST http://localhost:4000/api/productora -H \"Content-Type: application/json\" -d '{\"nombre\": \"Universal Pictures\", \"slogan\": \"Creating Magic\", \"descripcion\": \"Empresa productora\"}'",
      "obtener_todos": "curl -X GET http://localhost:4000/api/productora -H \"Content-Type: application/json\"",
      "actualizar": "curl -X PUT http://localhost:4000/api/productora/ID -H \"Content-Type: application/json\" -d '{\"nombre\": \"Universal Pictures\"}'",
      "eliminar": "curl -X DELETE http://localhost:4000/api/productora/ID -H \"Content-Type: application/json\""
    },
    "tipo": {
      "crear": "curl -X POST http://localhost:4000/api/tipo -H \"Content-Type: application/json\" -d '{\"nombre\": \"Película\", \"descripcion\": \"Contenido de formato película\"}'",
      "obtener_todos": "curl -X GET http://localhost:4000/api/tipo -H \"Content-Type: application/json\"",
      "actualizar": "curl -X PUT http://localhost:4000/api/tipo/ID -H \"Content-Type: application/json\" -d '{\"nombre\": \"Serie\"}'",
      "eliminar": "curl -X DELETE http://localhost:4000/api/tipo/ID -H \"Content-Type: application/json\""
    },
    "media": {
      "crear": "curl -X POST http://localhost:4000/api/media -H \"Content-Type: application/json\" -d '{\"serial\": \"UNIVERS-001\", \"titulo\": \"Jaws\", \"urlPelicula\": \"https://www.peliculas.com/jaws\", \"anioEstreno\": 1975, \"genero\": \"GENERO_ID\", \"director\": \"DIRECTOR_ID\", \"productora\": \"PRODUCTORA_ID\", \"tipo\": \"TIPO_ID\"}'",
      "obtener_todos": "curl -X GET http://localhost:4000/api/media -H \"Content-Type: application/json\"",
      "actualizar": "curl -X PUT http://localhost:4000/api/media/ID -H \"Content-Type: application/json\" -d '{\"titulo\": \"Jaws\", \"anioEstreno\": 1975}'",
      "eliminar": "curl -X DELETE http://localhost:4000/api/media/ID -H \"Content-Type: application/json\""
    }
  }
