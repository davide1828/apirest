  "modulo_director": {
    "get_todos_directores": {
      "metodo": "GET",
      "url": "http://localhost:4000/api/director",
      "headers": {
        "Content-Type": "application/json"
      },
      "descripcion": "Obtiene la lista de todos los directores",
      "respuesta_esperada": {
        "status": 200,
        "body": [
          {
            "_id": "507f1f77bcf86cd799439015",
            "nombre": "Steven Spielberg",
            "estado": "Activo",
            "fechaCreacion": "2024-01-15T10:30:00.000Z",
            "fechaActualizacion": "2024-01-15T10:30:00.000Z"
          }
        ]
      }
    },
    "post_crear_director": {
      "metodo": "POST",
      "url": "http://localhost:4000/api/director",
      "headers": {
        "Content-Type": "application/json"
      },
      "descripcion": "Crea un nuevo director",
      "body": {
        "nombre": "Steven Spielberg"
      },
      "campos_requeridos": [
        {
          "campo": "nombre",
          "tipo": "string",
          "descripcion": "Nombre del director",
          "validaciones": [
            "Requerido",
            "Único en la base de datos",
            "Se elimina espacios en blanco al inicio y final"
